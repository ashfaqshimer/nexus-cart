# PostgreSQL (used by docker-compose and the app)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexus_cart
POSTGRES_PORT=5432

# Connection string consumed by Drizzle / the app
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_cart

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000
