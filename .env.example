# PostgreSQL (used by docker-compose and the app)
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexus_cart
POSTGRES_PORT=5432

# Connection string consumed by Drizzle / the app.
# Local: the docker-compose Postgres below.
# Production (Vercel + Neon): set DATABASE_URL in the Vercel project to Neon's
#   POOLED connection string (the `-pooler` host) for Production + Preview.
#   For local migrations/seeding against Neon, use the DIRECT (non-pooler) URL:
#     DATABASE_URL="<neon-direct-url>" pnpm db:migrate
#     DATABASE_URL="<neon-direct-url>" pnpm db:seed
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_cart

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000
# Seed admin credentials — `pnpm db:seed` creates this user with role "admin".
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123

# Stripe (test mode). Get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret. Locally, run:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# and copy the printed `whsec_...` value here.
STRIPE_WEBHOOK_SECRET=whsec_...
# Base URL used to build Stripe success/cancel redirect URLs.
APP_URL=http://localhost:3000
